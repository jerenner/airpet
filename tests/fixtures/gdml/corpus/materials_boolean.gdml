<?xml version="1.0" encoding="UTF-8"?>
<gdml>
  <materials>
    <material name="Air" state="gas" Z="7.3">
      <D value="1.205e-3" unit="g/cm3"/>
      <atom value="14.61"/>
    </material>
    <material name="Aluminum" state="solid" Z="13">
      <D value="2.70" unit="g/cm3"/>
      <atom value="26.9815"/>
    </material>
  </materials>
  <solids>
    <box name="world_box" x="200" y="200" z="200" lunit="mm"/>
    <box name="housing_outer" x="60" y="40" z="20" lunit="mm"/>
    <box name="housing_void" x="40" y="20" z="12" lunit="mm"/>
    <subtraction name="housing_cut">
      <first ref="housing_outer"/>
      <second ref="housing_void"/>
    </subtraction>
  </solids>
  <structure>
    <volume name="housing_lv">
      <materialref ref="Aluminum"/>
      <solidref ref="housing_cut"/>
    </volume>
    <volume name="world_lv">
      <materialref ref="Air"/>
      <solidref ref="world_box"/>
      <physvol name="housing_pv" copynumber="1">
        <volumeref ref="housing_lv"/>
        <position unit="mm" x="15" y="0" z="0"/>
      </physvol>
    </volume>
  </structure>
  <setup name="Default" version="1.0">
    <world ref="world_lv"/>
  </setup>
</gdml>
