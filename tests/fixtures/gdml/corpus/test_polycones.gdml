<?xml version="1.0" encoding="UTF-8" ?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://service-spi.web.cern.ch/service-spi/app/releases/GDML/schema/gdml.xsd">

  <define>
    <!-- Positions for placing the test objects -->
    <position name="pos_solid_cone" x="-300" y="0" z="0" unit="mm"/>
    <position name="pos_hollow_cone" x="0" y="0" z="0" unit="mm"/>
    <position name="pos_segmented_cone" x="300" y="0" z="0" unit="mm"/>
    <position name="pos_generic_cone" x="0" y="-300" z="0" unit="mm"/>
    <rotation name="identity" x="0" y="0" z="0" unit="deg"/>
  </define>

  <materials>
    <material name="Vacuum" Z="1.0">
      <D value="1.0e-25" unit="g/cm3"/>
    </material>
    <material name="Lead" Z="82.0">
      <D value="11.35" unit="g/cm3"/>
    </material>
  </materials>

  <solids>
    <box name="WorldBox" x="1000" y="1000" z="1000" lunit="mm"/>

    <!-- 1. A simple solid polycone (like a traffic cone) -->
    <polycone name="SolidTrafficCone" startphi="0" deltaphi="360" aunit="deg" lunit="mm">
      <zplane rmin="0" rmax="50" z="-100"/>
      <zplane rmin="0" rmax="10" z="100"/>
    </polycone>

    <!-- 2. A hollow polycone with a variable inner radius (like a nozzle) -->
    <polycone name="HollowNozzle" startphi="0" deltaphi="360" aunit="deg" lunit="mm">
      <zplane rmin="20" rmax="50" z="-100"/>
      <zplane rmin="30" rmax="40" z="0"/>
      <zplane rmin="5"  rmax="15" z="100"/>
    </polycone>

    <!-- 3. A segmented, hollow polycone (half a tube) -->
    <polycone name="SegmentedCone" startphi="0" deltaphi="180" aunit="deg" lunit="mm">
      <zplane rmin="40" rmax="60" z="-80"/>
      <zplane rmin="40" rmax="60" z="80"/>
    </polycone>
    
    <!-- 4. A genericPolycone with a curved profile (like a vase) -->
    <genericPolycone name="VaseShape" startphi="0" deltaphi="360" aunit="deg" lunit="mm">
      <rzpoint r="30" z="-100"/>
      <rzpoint r="50" z="-80"/>
      <rzpoint r="40" z="0"/>
      <rzpoint r="60" z="80"/>
      <rzpoint r="50" z="100"/>
    </genericPolycone>

  </solids>

  <structure>
    <!-- Logical Volumes for each test solid -->
    <volume name="lvSolidTrafficCone">
      <materialref ref="Lead"/>
      <solidref ref="SolidTrafficCone"/>
    </volume>
    <volume name="lvHollowNozzle">
      <materialref ref="Lead"/>
      <solidref ref="HollowNozzle"/>
    </volume>
    <volume name="lvSegmentedCone">
      <materialref ref="Lead"/>
      <solidref ref="SegmentedCone"/>
    </volume>
    <volume name="lvVaseShape">
        <materialref ref="Lead"/>
        <solidref ref="VaseShape"/>
    </volume>

    <!-- World Volume and Placements -->
    <volume name="lvWorld">
      <materialref ref="Vacuum"/>
      <solidref ref="WorldBox"/>
      
      <physvol name="pvSolidCone">
        <volumeref ref="lvSolidTrafficCone"/>
        <positionref ref="pos_solid_cone"/>
        <rotationref ref="identity"/>
      </physvol>

      <physvol name="pvHollowNozzle">
        <volumeref ref="lvHollowNozzle"/>
        <positionref ref="pos_hollow_cone"/>
        <rotationref ref="identity"/>
      </physvol>
      
      <physvol name="pvSegmentedCone">
        <volumeref ref="lvSegmentedCone"/>
        <positionref ref="pos_segmented_cone"/>
        <rotationref ref="identity"/>
      </physvol>
      
      <physvol name="pvVaseShape">
        <volumeref ref="lvVaseShape"/>
        <positionref ref="pos_generic_cone"/>
        <rotationref ref="identity"/>
      </physvol>

    </volume>
  </structure>

  <setup name="Default" version="1.0">
    <world ref="lvWorld"/>
  </setup>

</gdml>
