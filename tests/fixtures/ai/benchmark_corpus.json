  {
    "name": "param_study_setup",
    "prompt": "Set up a grid study for the slab thickness define and optimize success plus placement count.",
    "preconditions": [
      {
        "tool": "manage_define",
        "args": {
          "name": "slab_thickness",
          "define_type": "constant",
          "value": "0.5",
          "unit": "mm"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "created"
          }
        }
      }
    ],
    "trace": [
      {
        "tool": "create_parameter_registry",
        "args": {
          "param_name": "slab_thickness",
          "target_type": "define",
          "target_ref": {
            "name": "slab_thickness"
          },
          "bounds": {
            "min": 0.2,
            "max": 1.0
          },
          "default": 0.5,
          "units": "mm"
        },
        "expected": {
          "success": true,
          "parameter": {
            "name": "slab_thickness",
            "target_type": "define",
            "default": 0.5,
            "bounds": {
              "min": 0.2,
              "max": 1.0
            }
          }
        }
      },
      {
        "tool": "setup_param_study",
        "args": {
          "study_name": "slab_thickness_grid",
          "mode": "grid",
          "parameters": [
            "slab_thickness"
          ],
          "objectives": [
            {
              "name": "success",
              "metric": "success_flag",
              "direction": "maximize"
            },
            {
              "name": "placements",
              "metric": "placements_count",
              "direction": "maximize"
            }
          ],
          "grid": {
            "steps": 3
          }
        },
        "expected": {
          "success": true,
          "study": {
            "name": "slab_thickness_grid",
            "mode": "grid",
            "parameters": [
              "slab_thickness"
            ],
            "grid": {
              "steps": 3
            }
          }
        }
      }
    ],
    "expected_state": {
      "parameter_registry": {
        "slab_thickness": {
          "target_type": "define",
          "bounds": {
            "min": 0.2,
            "max": 1.0
          }
        }
      },
      "param_studies": {
        "slab_thickness_grid": {
          "mode": "grid",
          "parameters": [
            "slab_thickness"
          ],
          "grid": {
            "steps": 3
          }
        }
      }
    }
  }
