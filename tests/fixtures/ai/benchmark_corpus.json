[
  {
    "name": "slab_and_beam_setup",
    "prompt": "Turn the default box into a 10 mm silicon slab and aim a 10 keV electron beam at it.",
    "trace": [
      {
        "tool": "manage_material",
        "args": {
          "name": "G4_Si"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "created"
          }
        }
      },
      {
        "tool": "modify_solid",
        "args": {
          "name": "box_solid",
          "params": {
            "x": "10 mm",
            "y": "10 mm",
            "z": "0.5 mm"
          }
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "updated"
          }
        }
      },
      {
        "tool": "manage_logical_volume",
        "args": {
          "name": "box_LV",
          "solid_ref": "box_solid",
          "material_ref": "G4_Si"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "updated"
          }
        }
      },
      {
        "tool": "configure_incident_beam",
        "args": {
          "target": "box_LV",
          "source_name": "slab_beam",
          "particle": "electron",
          "energy": "10 keV",
          "incident_axis": "+z",
          "offset": "1*mm"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "configured"
          },
          "source": {
            "name": "slab_beam",
            "target_pv_name": "box_PV",
            "target_sensitive_updated": true,
            "gps_commands": {
              "particle": "e-",
              "ang/type": "beam1d",
              "energy": "10*keV"
            }
          }
        }
      }
    ],
    "expected_state": {
      "materials": {
        "G4_Si": {
          "mat_type": "nist"
        }
      },
      "solids": {
        "box_solid": {
          "_evaluated_parameters": {
            "x": 10.0,
            "y": 10.0,
            "z": 0.5
          }
        }
      },
      "logical_volumes": {
        "box_LV": {
          "material_ref": "G4_Si",
          "is_sensitive": true
        }
      },
      "active_source_ids": {
        "$len": 1
      },
      "sources": {
        "slab_beam": {
          "name": "slab_beam",
          "gps_commands": {
            "particle": "e-",
            "ang/type": "beam1d",
            "energy": "10*keV"
          }
        }
      }
    }
  },
  {
    "name": "define_update",
    "prompt": "Increase the slab thickness define from 0.5 mm to 0.8 mm and keep the dependent geometry in sync.",
    "preconditions": [
      {
        "tool": "manage_define",
        "args": {
          "name": "slab_thickness",
          "define_type": "constant",
          "value": "0.5",
          "unit": "mm"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "created"
          }
        }
      },
      {
        "tool": "modify_solid",
        "args": {
          "name": "box_solid",
          "params": {
            "x": "10 mm",
            "y": "10 mm",
            "z": "slab_thickness"
          }
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "updated"
          }
        }
      }
    ],
    "trace": [
      {
        "tool": "manage_define",
        "args": {
          "name": "slab_thickness",
          "define_type": "constant",
          "value": "0.8",
          "unit": "mm"
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "updated"
          }
        }
      }
    ],
    "expected_state": {
      "defines": {
        "slab_thickness": {
          "unit": "mm",
          "value": 0.8
        }
      },
      "solids": {
        "box_solid": {
          "_evaluated_parameters": {
            "z": 0.8
          }
        }
      }
    }
  },
  {
    "name": "run_simulation",
    "prompt": "Run a 250-event simulation with a 0.5 mm production cut, 20 eV hit threshold, saved hits, and FTFP_BERT optics.",
    "trace": [
      {
        "tool": "run_simulation",
        "args": {
          "events": 250,
          "threads": 2,
          "production_cut": "0.5 mm",
          "hit_energy_threshold": "20 eV",
          "save_hits": true,
          "save_hit_metadata": true,
          "save_particles": true,
          "save_tracks_range": "0-9",
          "seed1": 11,
          "seed2": 22,
          "print_progress": 250,
          "physics_list": "FTFP_BERT",
          "optical_physics": true
        },
        "expected": {
          "success": true,
          "message": {
            "$contains": "Simulation started"
          },
          "preflight_summary": {
            "can_run": true
          },
          "job_id": {
            "$exists": true
          }
        }
      }
    ],
    "expected_state": {
      "current_version_id": "benchmark-version",
      "is_changed": false
    }
  },
