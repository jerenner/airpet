{
  "experiment_name": "m5_baseline_gp",
  "dataset": {
    "manifest": "surrogate/datasets/m5_dataset/manifest.json",
    "train_csv": "surrogate/datasets/m5_dataset/train.csv",
    "val_csv": "surrogate/datasets/m5_dataset/val.csv"
  },
  "model": {
    "type": "gp",
    "allowed_types": ["gp", "mlp"],
    "gp": {
      "length_scale": null,
      "noise": 1e-6
    },
    "mlp": {
      "hidden_size": 16,
      "epochs": 400,
      "learning_rate": 0.01,
      "l2": 0.0
    }
  },
  "features": {
    "input_params": ["p1", "p2"],
    "target_objective": "success",
    "feature_scaling": {
      "enabled": true,
      "method": "standard"
    }
  },
  "split": {
    "source": "precomputed",
    "val_ratio": 0.2,
    "seed": 42
  },
  "training": {
    "seed": 42
  },
  "output": {
    "root": "surrogate/experiments"
  }
}
